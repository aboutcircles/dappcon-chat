# HMAC secret for the session cookie. Required in production (≥16 chars).
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Optional: where the JSON-backed store lives. Defaults to /tmp/dmdappcon-data.json.
# DATA_FILE=/var/lib/dmdappcon/data.json

# Optional: override the Gnosis Chain RPC used for EIP-1271 sign-in verification.
# GNOSIS_RPC_URL=https://rpc.gnosischain.com

